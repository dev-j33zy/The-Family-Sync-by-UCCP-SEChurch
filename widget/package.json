{
  "name": "family-sync-widget",
  "version": "1.2.9",
  "description": "Desktop widget showing upcoming birthdays and anniversaries from The Family Sync",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "generate-icons": "node scripts/generate-icons.js",
    "build": "npm run generate-icons && electron-builder --win nsis",
    "build:portable": "npm run generate-icons && electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "sharp": "^0.35.2"
  },
  "build": {
    "appId": "com.uccp.family-sync-widget",
    "productName": "Family Sync Widget",
    "icon": "assets/icon-256.png",
    "win": {
      "target": "nsis",
      "icon": "assets/icon-256.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "shortcutName": "Family Sync Widget",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
